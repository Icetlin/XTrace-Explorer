# Copy to .env and fill in your paths

# Directory with your .xt trace files
TRACES_DIR=/path/to/xdebug_traces

# Source code of the traced project (for inline source view)
# SOURCE_HOST_DIR — path on your machine
# SOURCE_CONTAINER_DIR — path xdebug recorded in the trace (check any file:line in the trace)
SOURCE_HOST_DIR=/path/to/project/source
SOURCE_CONTAINER_DIR=/var/www/your-app
