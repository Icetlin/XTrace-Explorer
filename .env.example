# Host path to the directory where xdebug writes .xt trace files
TRACES_DIR=/path/to/xdebug_traces

# Inline source view — path mapping for your PHP project (same as PHPStorm Xdebug server mapping)
# Left column (local path on host):
SOURCE_HOST_DIR=/home/me/projects/my-app
# Right column (path inside the PHP container):
SOURCE_CONTAINER_DIR=/var/www/my-app

# Xdebug mode switcher — name of your PHP container and path to its compose project
# Leave empty to disable the Xdebug tab in Settings
XDEBUG_CONTAINER=
XDEBUG_TRACE_DIR_CTR=

# ── Profiler+ ──────────────────────────────────────────────────────────────
# Pulls SQL queries with full backtraces from the target app's Symfony
# WebProfilerBundle. Only one env var is needed:
#
# The host of the target app (where /_profiler lives). Must be reachable
# FROM THIS CONTAINER. Examples:
#   https://systeme.local          # only works if container can see the host
#   https://192.168.1.10:443       # use the host's LAN IP from inside the container
#   https://host.docker.internal    # Docker Desktop (Mac/Windows) — already mapped
#
# Common pitfall on Linux: systeme.local on the HOST points at 127.0.0.1,
# but the container resolves 127.0.0.1 to itself. To reach the host's
# localhost from the container, either:
#   1. Set `network_mode: host` for the `app` service in docker-compose.yml
#   2. Bind the dev server to 0.0.0.0 and use the host's LAN IP here
#   3. Use ssh -L / kubectl port-forward and point at 127.0.0.1
#
# The path mapping for backtrace files is taken from SOURCE_HOST_DIR and
# SOURCE_CONTAINER_DIR above (shared with the inline source view). The
# enabled/disabled toggle is a per-user preference stored in the
# `app_setting` table — toggle it from Settings → Profiler+ in the UI.
PROFILER_BASE_URL=
